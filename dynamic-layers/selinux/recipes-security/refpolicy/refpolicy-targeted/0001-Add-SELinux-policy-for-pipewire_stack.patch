From 5d97609d2bdd5d7fce41429b614cc6a76d601c11 Mon Sep 17 00:00:00 2001
From: Chiluka Rohith <rchiluka@qti.qualcomm.com>
Date: Thu, 16 Apr 2026 19:57:08 +0530
Subject: [PATCH] Add SELinux policy for pipewire_stack

Introduce a new SELinux policy module 'pipewire_stack' to confine the
PipeWire multimedia daemon and its associated runtime under a dedicated
least-privilege domain.

Changes include:

- pipewire_stack.fc: File context definitions for PipeWire executable,
  configuration, shared data, runtime sockets and persistent state.

  /usr/bin/pipewire is labeled pipewire_exec_t. pipewire-pulse is a
  symlink to pipewire and inherits the same exec label, so no separate
  domain is needed for it.

- pipewire_stack.if: Interface file stub reserved for future cross-module
  interface definitions.

- pipewire_stack.te: Type enforcement policy for the pipewire_t domain
  covering:
  - Process control: fork, signal handling (sigchld, signal) and
    scheduling (sys_nice) for low-latency audio operation. signal is
    required for pipewire's internal watchdog/realtime thread signalling
    to itself (tgkill SIGABRT).
  - Runtime socket and directory management under /run/pipewire
  - ALSA sound device access (sound_device_t)
  - DMA device access (dma_device_t) for hardware audio offload
  - Shared memory (tmpfs/memfd) for zero-copy audio buffer handling
  - PulseAudio runtime compatibility (/run/pulse probing and PID file
    management)
  - sysfs and procfs read access for hardware discovery
  - System logging via syslog and systemd journal
  - Suppressed audit noise for expected /proc scan denials via
    dontaudit rules for initrc_t and unconfined_t process entries,
    with unconfined_t rules wrapped in optional_policy to handle
    builds where the unconfined module is absent

Upstream-Status: Pending [to be submitted to SELinuxProject/refpolicy]

Signed-off-by: Chiluka Rohith <rchiluka@qti.qualcomm.com>
---
 policy/modules/services/pipewire_stack.fc |  12 ++
 policy/modules/services/pipewire_stack.if |   1 +
 policy/modules/services/pipewire_stack.te | 152 ++++++++++++++++++++++
 3 files changed, 165 insertions(+)
 create mode 100644 policy/modules/services/pipewire_stack.fc
 create mode 100644 policy/modules/services/pipewire_stack.if
 create mode 100644 policy/modules/services/pipewire_stack.te

diff --git a/policy/modules/services/pipewire_stack.fc b/policy/modules/services/pipewire_stack.fc
new file mode 100644
index 000000000..ee2f6923f
--- /dev/null
+++ b/policy/modules/services/pipewire_stack.fc
@@ -0,0 +1,12 @@
+# --- Executables ---
+/usr/bin/pipewire                   --  gen_context(system_u:object_r:pipewire_exec_t,s0)
+
+# --- Config and data ---
+/etc/pipewire(/.*)?                     gen_context(system_u:object_r:pipewire_etc_t,s0)
+/usr/share/pipewire(/.*)?               gen_context(system_u:object_r:pipewire_share_t,s0)
+
+# --- Runtime directories ---
+/run/pipewire(/.*)?                     gen_context(system_u:object_r:pipewire_run_t,s0)
+
+# --- Persistent state ---
+/var/lib/pipewire(/.*)?                 gen_context(system_u:object_r:pipewire_var_lib_t,s0)
diff --git a/policy/modules/services/pipewire_stack.if b/policy/modules/services/pipewire_stack.if
new file mode 100644
index 000000000..eaa922193
--- /dev/null
+++ b/policy/modules/services/pipewire_stack.if
@@ -0,0 +1 @@
+## <summary>Policy for pipewire and pipewire-pulse stack.</summary>
diff --git a/policy/modules/services/pipewire_stack.te b/policy/modules/services/pipewire_stack.te
new file mode 100644
index 000000000..9370f8751
--- /dev/null
+++ b/policy/modules/services/pipewire_stack.te
@@ -0,0 +1,152 @@
+policy_module(pipewire_stack, 1.0)
+
+########################################
+# External Declarations & Tunables
+########################################
+gen_require(`
+	type sound_device_t;
+	type pulseaudio_runtime_t;
+	type dma_device_t;
+	type tmpfs_t;
+	type initrc_t;
+')
+
+########################################
+# Types & Domains
+########################################
+
+# PipeWire daemon
+type pipewire_t;
+type pipewire_exec_t;
+init_daemon_domain(pipewire_t, pipewire_exec_t)
+
+########################################
+# File and Directory Types
+########################################
+
+# Config file contexts
+type pipewire_etc_t;
+files_config_file(pipewire_etc_t)
+
+# Shared configuration and presets
+type pipewire_share_t;
+files_type(pipewire_share_t)
+
+# Runtime directories
+type pipewire_run_t;
+files_runtime_file(pipewire_run_t)
+
+# Persistent state
+type pipewire_var_lib_t;
+files_type(pipewire_var_lib_t)
+
+########################################
+# Baseline Capabilities and Library Access
+########################################
+
+corecmd_exec_bin(pipewire_t)
+files_read_etc_files(pipewire_t)
+files_read_usr_files(pipewire_t)
+libs_use_ld_so(pipewire_t)
+libs_read_lib_files(pipewire_t)
+
+########################################
+# Process Control and Capabilities
+########################################
+
+allow pipewire_t self:process { fork sigchld signal getsched setsched };
+allow pipewire_t self:capability { sys_nice };
+
+########################################
+# Runtime Directory and Socket Handling
+########################################
+
+# PipeWire native runtime (/run/pipewire)
+files_runtime_filetrans(pipewire_t, pipewire_run_t, dir)
+allow pipewire_t pipewire_run_t:dir { create add_name remove_name write read getattr search };
+allow pipewire_t pipewire_run_t:sock_file { create unlink write read getattr };
+allow pipewire_t pipewire_run_t:file { create open read write getattr unlink lock };
+
+########################################
+# Hardware Device Access
+########################################
+
+# ALSA sound devices (/dev/snd/*, /dev/dsp*, etc.)
+allow pipewire_t sound_device_t:chr_file { open read write ioctl getattr };
+
+########################################
+# System Logging
+########################################
+
+systemd_read_journal_files(pipewire_t)
+logging_send_syslog_msg(pipewire_t)
+
+########################################
+# System Probing and Runtime Introspection
+########################################
+
+# sysfs read (transparent hugepage probe)
+dev_read_sysfs(pipewire_t)
+
+# procfs read (cpuinfo, asound/cards)
+kernel_read_system_state(pipewire_t)
+
+########################################
+# Configuration Access
+########################################
+
+# /etc/pipewire config access
+allow pipewire_t pipewire_etc_t:dir { search read open getattr };
+allow pipewire_t pipewire_etc_t:file { read open getattr map };
+
+# /usr/share/pipewire config access
+allow pipewire_t pipewire_share_t:dir { search read open getattr };
+allow pipewire_t pipewire_share_t:file { read open getattr map };
+
+########################################
+# Persistent State Access
+########################################
+
+# /var/lib/pipewire state access
+files_var_lib_filetrans(pipewire_t, pipewire_var_lib_t, { dir file })
+manage_dirs_pattern(pipewire_t, pipewire_var_lib_t, pipewire_var_lib_t)
+manage_files_pattern(pipewire_t, pipewire_var_lib_t, pipewire_var_lib_t)
+
+########################################
+# IPC and Memory Handling
+########################################
+
+# Self unix socket: create, bind, listen, accept, connect
+allow pipewire_t self:unix_stream_socket { create bind listen accept connectto read write getattr };
+
+# memfd shared memory (tmpfs-backed)
+allow pipewire_t tmpfs_t:file { read write getattr map };
+
+# Internal pipes
+allow pipewire_t self:fifo_file { read write };
+
+########################################
+# Compatibility with PulseAudio Runtime
+########################################
+
+# /run/pulse probing for PulseAudio compatibility
+allow pipewire_t pulseaudio_runtime_t:dir { getattr search };
+
+# DMA device access for hardware audio offload
+allow pipewire_t dma_device_t:chr_file { read open getattr ioctl };
+
+# PulseAudio runtime dir - pid file creation
+allow pipewire_t pulseaudio_runtime_t:dir { write add_name remove_name };
+allow pipewire_t pulseaudio_runtime_t:file { create write read open getattr unlink lock };
+
+# Suppress /proc scan denials - pipewire enumerates /proc for process discovery
+dontaudit pipewire_t initrc_t:file read;
+dontaudit pipewire_t initrc_t:lnk_file read;
+dontaudit pipewire_t initrc_t:dir search;
+optional_policy(`
+	gen_require(`
+		type unconfined_t;
+	')
+	dontaudit pipewire_t unconfined_t:lnk_file read;
+	dontaudit pipewire_t unconfined_t:dir search;
+')
-- 
