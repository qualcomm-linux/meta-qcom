From e62b1235207de2b1d293aec34e5c26c496a42fad Mon Sep 17 00:00:00 2001
From: Stoyan Kushlev <skushlev@qti.qualcomm.com>
Date: Thu, 4 Jun 2026 18:33:09 +0300
Subject: [PATCH 6/6] CAMX: IL: Add BT2020_HLG color space profile definition

Camera HAL has support for BT2020_HLG color space profile.
We need to add the BT2020_HLG color space profile in the
available color space profiles map to support this format.

Add BT2020_HLG color space profile definition.

Upstream-Status: Inappropriate [Qualcomm specific change]

Signed-off-by: Stoyan Kushlev <skushlev@qti.qualcomm.com>
---
 camera/include/system/camera_metadata_tags.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/camera/include/system/camera_metadata_tags.h b/camera/include/system/camera_metadata_tags.h
index 72186185..101b298d 100644
--- a/camera/include/system/camera_metadata_tags.h
+++ b/camera/include/system/camera_metadata_tags.h
@@ -1110,6 +1110,7 @@ typedef enum camera_metadata_enum_android_request_available_color_space_profiles
     ANDROID_REQUEST_AVAILABLE_COLOR_SPACE_PROFILES_MAP_ACESCG        = 13, // HIDL v3.9
     ANDROID_REQUEST_AVAILABLE_COLOR_SPACE_PROFILES_MAP_CIE_XYZ       = 14, // HIDL v3.9
     ANDROID_REQUEST_AVAILABLE_COLOR_SPACE_PROFILES_MAP_CIE_LAB       = 15, // HIDL v3.9
+    ANDROID_REQUEST_AVAILABLE_COLOR_SPACE_PROFILES_MAP_BT2020_HLG    = 16, // AIDL v2.0
 } camera_metadata_enum_android_request_available_color_space_profiles_map_t;
 
 
