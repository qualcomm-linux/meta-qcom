From 246ec825c17e203953796297b943aad5b61149e7 Mon Sep 17 00:00:00 2001
From: Stoyan Kushlev <skushlev@qti.qualcomm.com>
Date: Thu, 4 Jun 2026 17:35:30 +0300
Subject: [PATCH 4/5] CAMX: CORE: Add support for YUV 420 P010.

Camera HAL has support for YUV 420 P010 image format.
We need to add the YUV 420 P010 image format in the
scaler available formats to support this format.

Add support for YUV 420 P010.

Upstream-Status: Inappropriate [Qualcomm specific change]

Signed-off-by: Stoyan Kushlev <skushlev@qti.qualcomm.com>
---
 camera/include/system/camera_metadata_tags.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/camera/include/system/camera_metadata_tags.h b/camera/include/system/camera_metadata_tags.h
index ab0be6ed..ba24dc86 100644
--- a/camera/include/system/camera_metadata_tags.h
+++ b/camera/include/system/camera_metadata_tags.h
@@ -1122,6 +1122,7 @@ typedef enum camera_metadata_enum_android_scaler_available_formats {
     ANDROID_SCALER_AVAILABLE_FORMATS_BLOB                            = 0x21, // HIDL v3.2
     ANDROID_SCALER_AVAILABLE_FORMATS_RAW10                           = 0x25, // HIDL v3.4
     ANDROID_SCALER_AVAILABLE_FORMATS_RAW12                           = 0x26, // HIDL v3.4
+    ANDROID_SCALER_AVAILABLE_FORMATS_YCbCr_420_P010                  = 0x36, // HIDL v3.4
     ANDROID_SCALER_AVAILABLE_FORMATS_Y8                              = 0x20203859, // HIDL v3.4
 } camera_metadata_enum_android_scaler_available_formats_t;
 
