From 063da63893bc8127929584bc5f4d7ea5b5fb829a Mon Sep 17 00:00:00 2001
From: Stoyan Kushlev <skushlev@qti.qualcomm.com>
Date: Wed, 10 Jun 2026 17:36:11 +0300
Subject: [PATCH 1/3] Create CMakeListst for building the android cam metadata

Linux embedded uses CMake to build libraries, but the provided
code is from android repo. This request creating new CMakeLists.txt
for building the camera metadata lib.

Upstream-Status: Inappropriate [Yocto specific change]

Signed-off-by: Stoyan Kushlev <skushlev@qti.qualcomm.com>
---
 CMakeLists.txt      | 37 +++++++++++++++++++++++++++++++++++++
 camx_metadata.pc.in | 11 +++++++++++
 2 files changed, 48 insertions(+)
 create mode 100644 CMakeLists.txt
 create mode 100644 camx_metadata.pc.in

diff --git a/CMakeLists.txt b/CMakeLists.txt
new file mode 100644
index 00000000..18bb6a23
--- /dev/null
+++ b/CMakeLists.txt
@@ -0,0 +1,37 @@
+cmake_minimum_required(VERSION 3.16)
+
+# Define version - can be passed from Yocto via command line
+if(NOT DEFINED PROJECT_VERSION)
+    set(PROJECT_VERSION "0.1.0")
+endif()
+
+project(camx_metadata VERSION ${PROJECT_VERSION})
+
+# Add destination of compiletime pkg-config file to PKG_CONFIG_PATH
+set(ENV{PKG_CONFIG_PATH} "${CMAKE_CURRENT_BINARY_DIR}:$ENV{PKG_CONFIG_PATH}")
+
+configure_file(
+  camx_metadata.pc.in
+  camx_metadata.pc
+  @ONLY
+)
+
+# Files and Build Type
+add_library( camx_metadata SHARED
+    camera/src/camera_metadata.c
+)
+
+target_include_directories(camx_metadata PRIVATE
+    private/camera/include
+    camera/include
+)
+
+set_target_properties(camx_metadata PROPERTIES
+    VERSION ${PROJECT_VERSION}
+    SOVERSION ${PROJECT_VERSION_MAJOR}
+    OUTPUT_NAME "camx_metadata"
+)
+
+install(TARGETS camx_metadata DESTINATION lib)
+install(DIRECTORY camera/include/system DESTINATION include)
+install(FILES ${CMAKE_CURRENT_BINARY_DIR}/camx_metadata.pc DESTINATION lib/pkgconfig)
\ No newline at end of file
diff --git a/camx_metadata.pc.in b/camx_metadata.pc.in
new file mode 100644
index 00000000..77fb385a
--- /dev/null
+++ b/camx_metadata.pc.in
@@ -0,0 +1,11 @@
+prefix=@CMAKE_INSTALL_PREFIX@
+exec_prefix=${prefix}
+libdir=${exec_prefix}/lib
+includedir=${prefix}/include/system
+
+Name: camx_metadata
+Description: Android camera metadata library
+Version: @PROJECT_VERSION@
+Libs: -L${libdir} -lcamx_metadata
+Libs.private:
+Cflags: -I${includedir}
-- 
