From 8ac9ba4efbe0d05666e04d654491d2ef83e08bce Mon Sep 17 00:00:00 2001
From: Dmitry Baryshkov <dmitry.baryshkov@oss.qualcomm.com>
Date: Tue, 19 Aug 2025 23:11:44 +0300
Subject: [PATCH 3/8] kgsl: mark _kgsl_set_smmu_aperture() as static

Mark _kgsl_set_smmu_aperture() as static in order to fix the warning
regarding the function withoug the prototype.

Fixes: da8965d6a0c7 ("kgsl: Enable KGSL driver compilation with upstream kernel")
Signed-off-by: Dmitry Baryshkov <dmitry.baryshkov@oss.qualcomm.com>
Upstream-Status: Submitted [https://github.com/qualcomm-linux/kgsl/pull/9]
---
 kgsl_iommu.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/kgsl_iommu.c b/kgsl_iommu.c
index 24eb24a640a5..bd415fa2c050 100644
--- a/kgsl_iommu.c
+++ b/kgsl_iommu.c
@@ -1335,12 +1335,12 @@ static void _enable_gpuhtw_llc(struct kgsl_mmu *mmu, struct iommu_domain *domain
 }
 
 #if (KERNEL_VERSION(6, 13, 0) <= LINUX_VERSION_CODE)
-int _kgsl_set_smmu_aperture(u32 num_context_bank)
+static int _kgsl_set_smmu_aperture(u32 num_context_bank)
 {
 	return qcom_scm_set_gpu_smmu_aperture(num_context_bank);
 }
 #else
-int _kgsl_set_smmu_aperture(u32 num_context_bank)
+static int _kgsl_set_smmu_aperture(u32 num_context_bank)
 {
 	return qcom_scm_kgsl_set_smmu_aperture(num_context_bank);
 }
-- 
2.47.2

